### EmitterComponent

# Shows when attempting to turn the emitter on or off without proper access
comp-emitter-access-locked = {$target} está bloqueado por acesso!

# Shows when turning the emitter on/off
comp-emitter-turned-on = {$target} liga.

comp-emitter-turned-off = {$target} desliga.

# Shows if the user attempts to activate the emitter while it's un-anchored.
comp-emitter-not-anchored = {$target} não está fixado ao chão!

# Upgrades
emitter-component-upgrade-fire-rate = cadência de tiro

emitter-component-current-type = O tipo selecionado atualmente é: {$type}.
emitter-component-type-set = Tipo definido como: {$type}