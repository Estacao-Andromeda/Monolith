execution-verb-name = Executar
execution-verb-message = Use sua arma para executar alguém.

# Todas as strings de localizacao abaixo tem acesso as seguintes variaveis
# attacker (a pessoa cometendo a execucao)
# victim (a pessoa sendo executada)
# weapon (a arma usada na execucao)

execution-popup-melee-initial-internal = Você prepara {THE($weapon)} contra a garganta de {THE($victim)}.
execution-popup-melee-initial-external = { CAPITALIZE(THE($attacker)) } prepara {POSS-ADJ($attacker)} {$weapon} contra a garganta de {THE($victim)}.
execution-popup-melee-complete-internal = Você corta a garganta de {THE($victim)}!
execution-popup-melee-complete-external = { CAPITALIZE(THE($attacker)) } corta a garganta de {THE($victim)}!

execution-popup-self-initial-internal = Você prepara {THE($weapon)} contra sua propria garganta.
execution-popup-self-initial-external = { CAPITALIZE(THE($attacker)) } prepara {POSS-ADJ($attacker)} {$weapon} contra a propria garganta.
execution-popup-self-complete-internal = Você corta sua propria garganta!
execution-popup-self-complete-external = { CAPITALIZE(THE($attacker)) } corta a propria garganta!
