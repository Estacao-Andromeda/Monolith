### Localization used for the invoke verb command.
# Mostly help + error messages.

invoke-verb-command-description = Invoca um verbo com o nome dado em uma entidade, com a entidade do jogador

invoke-verb-command-help = invokeverb <playerUid | "self"> <targetUid> <verbName | "interaction" | "activation" | "alternative">

invoke-verb-command-invalid-args = invokeverb requer 2 argumentos.

invoke-verb-command-invalid-player-uid = O uid do jogador não pôde ser analisado, ou "self" não foi passado.

invoke-verb-command-invalid-target-uid = O uid do alvo não pôde ser analisado.

invoke-verb-command-invalid-player-entity = O uid do jogador dado não corresponde a uma entidade válida.

invoke-verb-command-invalid-target-entity = O uid do alvo dado não corresponde a uma entidade válida.

invoke-verb-command-success = Verbo '{ $verb }' invocado em { $target } com { $player } como o usuário.

invoke-verb-command-verb-not-found = Não foi possível encontrar o verbo { $verb } em { $target }.
