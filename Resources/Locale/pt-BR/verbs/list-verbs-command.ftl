list-verbs-command-description = Lista todos os verbos que um jogador pode usar em uma dada entidade.

list-verbs-command-help = listverbs <playerUid | "self"> <targetUid>

list-verbs-command-invalid-args = listverbs requer 2 argumentos.

list-verbs-command-invalid-player-uid = O uid do jogador não pôde ser analisado, ou "self" não foi passado.

list-verbs-command-invalid-target-uid = O uid do alvo não pôde ser analisado.

list-verbs-command-invalid-player-entity = O uid do jogador dado não corresponde a uma entidade válida.

list-verbs-command-invalid-target-entity = O uid do alvo dado não corresponde a uma entidade válida.

list-verbs-verb-listing = { $type }: { $verb }
