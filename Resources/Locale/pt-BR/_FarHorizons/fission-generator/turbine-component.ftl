### Examine

# Shown when examining the turbine.
turbine-spinning-0 = As pás não estão girando.
turbine-spinning-1 = As pás estão girando lentamente.
turbine-spinning-2 = As pás estão girando.
turbine-spinning-3 = As pás estão girando rapidamente.
turbine-spinning-4 = [color=red]As pás estão girando fora de controle![/color]

turbine-damaged-0 = Parece estar em boas condições.[/color]
turbine-damaged-1 = A turbina parece um pouco danificada.[/color]
turbine-damaged-2 = [color=yellow]A turbina parece gravemente danificada.[/color]
turbine-damaged-3 = [color=orange]Está criticamente danificada![/color]

turbine-ruined = [color=red]Está completamente quebrada![/color]

### Popups

# Shown when an event occurs
turbine-overheat = {$owner} aciona a válvula de emergência de descarga de superaquecimento!
turbine-explode = O {$owner} se despedaça!

# Shown when damage occurs
turbine-spark = O {$owner} começa a soltar faíscas!
turbine-spark-stop = O {$owner} para de soltar faíscas.
turbine-smoke = O {$owner} começa a soltar fumaça!
turbine-smoke-stop = O {$owner} para de soltar fumaça.

# Shown during repairs
turbine-repair-ruined = Você repara a carcaça do {$target} com o {$tool}.
turbine-repair = Você repara alguns dos danos ao {$target} usando o {$tool}.
turbine-no-damage = Não há dano para reparar no {$target} usando o {$tool}.
turbine-show-damage = SaúdeDasPás {$health}, SaúdeMáximaDasPás {$healthMax}.

# Anchoring warnings
turbine-unanchor-warning = Você não pode desafixar a turbina a gás enquanto ela estiver girando!
turbine-anchor-warning = Posição de ancoragem inválida.

