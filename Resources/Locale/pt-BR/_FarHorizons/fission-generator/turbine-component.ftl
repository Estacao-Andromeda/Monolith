### Popups

# Shown when an event occurs
turbine-overheat = {$owner} aciona a vlvula de emergncia de descarga de superaquecimento!
turbine-explode = O {$owner} se despedaa!

# Shown when damage occurs
turbine-spark = O {$owner} comea a soltar fasucas!
turbine-spark-stop = O {$owner} para de soltar fasucas.
turbine-smoke = O {$owner} comea a soltar fumaa!
turbine-smoke-stop = O {$owner} para de soltar fumaa.

# Shown during repairs
turbine-repair-ruined = Voc repara a carcaa do {$target} com o {$tool}.
