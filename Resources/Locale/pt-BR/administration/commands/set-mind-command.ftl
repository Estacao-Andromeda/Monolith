set-mind-command-description = Transfere uma mente para a entidade especificada. A entidade deve ter um {$requiredComponent}. Por padrão, isso forçará mentes que estão atualmente visitando outras entidades a retornar (i.e., retornar um fantasma para seu corpo principal).
set-mind-command-help-text = Uso: {$command} <entityUid> <nomeDeUsuário> [unvisit]
set-mind-command-target-has-no-content-data-message = O jogador alvo não tem dados de conteúdo (wtf?)
set-mind-command-target-has-no-mind-message = A entidade alvo não tem uma mente (você esqueceu de tornar senciente?)
cmd-mind-command-hint = nomeDeUsuário
