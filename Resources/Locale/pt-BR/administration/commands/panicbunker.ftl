cmd-panicbunker-desc = Alterna o bunker de pânico, que habilita restrições mais estritas sobre quem tem permissão para entrar no servidor.
cmd-panicbunker-help = Uso: panicbunker
panicbunker-command-enabled = O bunker de pânico foi habilitado.
panicbunker-command-disabled = O bunker de pânico foi desabilitado.

cmd-panicbunker_disable_with_admins-desc = Alterna se o bunker de pânico será desabilitado quando um administrador se conectar.
cmd-panicbunker_disable_with_admins-help = Uso: panicbunker_disable_with_admins
panicbunker-command-disable-with-admins-enabled = O bunker de pânico será desabilitado automaticamente com administradores online.
panicbunker-command-disable-with-admins-disabled = O bunker de pânico não será desabilitado automaticamente com administradores online.

cmd-panicbunker_enable_without_admins-desc = Alterna se o bunker de pânico será habilitado quando o último administrador se desconectar.
cmd-panicbunker_enable_without_admins-help = Uso: panicbunker_enable_without_admins
panicbunker-command-enable-without-admins-enabled = O bunker de pânico será habilitado automaticamente sem administradores online.
panicbunker-command-enable-without-admins-disabled = O bunker de pânico não será habilitado automaticamente sem administradores online.

cmd-panicbunker_count_deadminned_admins-desc = Alterna se deve contar administradores desadminados ao habilitar e desabilitar automaticamente o bunker de pânico.
cmd-panicbunker_count_deadminned_admins-help = Uso: panicbunker_count_deadminned_admins
panicbunker-command-count-deadminned-admins-enabled = O bunker de pânico contará administradores desadminados quando for feito para habilitar e desabilitar automaticamente.
panicbunker-command-count-deadminned-admins-disabled = O bunker de pânico não contará administradores desadminados quando for feito para habilitar e desabilitar automaticamente.

cmd-panicbunker_show_reason-desc = Alterna se deve mostrar aos clientes que estão conectando o motivo pelo qual o bunker de pânico os bloqueou de entrar.
cmd-panicbunker_show_reason-help = Uso: panicbunker_show_reason
panicbunker-command-show-reason-enabled = O bunker de pânico agora mostrará um motivo aos usuários que bloqueia de conectar.
panicbunker-command-show-reason-disabled = O bunker de pânico não mostrará mais um motivo aos usuários que bloqueia de conectar.

cmd-panicbunker_min_account_age-desc = Obtém ou define a idade mínima da conta em minutos que uma conta deve ter para ter permissão para conectar com o bunker de pânico habilitado.
cmd-panicbunker_min_account_age-help = Uso: panicbunker_min_account_age <minutos>
panicbunker-command-min-account-age-is = A idade mínima da conta para o bunker de pânico é {$minutes} minutos.
panicbunker-command-min-account-age-set = Definida a idade mínima da conta para o bunker de pânico como {$minutes} minutos.

cmd-panicbunker_min_overall_minutes-desc = Obtém ou define o tempo de jogo geral mínimo em minutos que uma conta deve ter para ter permissão para conectar com o bunker de pânico habilitado.
cmd-panicbunker_min_overall_minutes-help = Uso: panicbunker_min_overall_minutes <minutos>
panicbunker-command-min-overall-minutes-is = O tempo de jogo geral mínimo para o bunker de pânico é {$minutes} minutos.
panicbunker-command-min-overall-minutes-set = Definido o tempo de jogo geral mínimo para o bunker de pânico como {$minutes} minutos.
