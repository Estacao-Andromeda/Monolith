# Voidsuit selectors

selectable-set-paramedic-voidsuit-name = Traje Espacial de Paramédico
selectable-set-paramedic-voidsuit-desc =
    Um traje espacial leve com proteção mínima
    mas com grande velocidade de movimento.

selectable-set-paramedic-modsuit-name = Modsuite Sanitar
selectable-set-paramedic-modsuit-desc =
    Uma modsuit modular com placas mais pesadas
    para aguentar um tiro ou dois, espero.

selectable-set-security-voidsuit-name = Traje Espacial de Segurança
selectable-set-security-voidsuit-desc =
    Um traje espacial leve com portador de placas embutido para proporcionar
    proteção moderada mantendo mobilidade para operações cinéticas de baixa intensidade.

selectable-set-security-modsuit-name = Modsuite de Segurança 'Soldado'
selectable-set-security-modsuit-desc =
    Uma modsuit modular com inserções de cerâmica para fornecer mais proteção
    que o traje espacial correspondente, mas com menos mobilidade.

selectable-set-headofsecurity-voidsuit-name = Traje Espacial do Chefe de Segurança
selectable-set-headofsecurity-voidsuit-desc =
    Um traje espacial leve com material cortado de áreas não vitais para levemente aumentar
    o valor de blindagem dos órgãos vitais e aumentar a mobilidade
    em comparação com o traje espacial de segurança padrão.

selectable-set-headofsecurity-modsuit-name = Modsuite 'Baluarte' do Chefe de Segurança
selectable-set-headofsecurity-modsuit-desc =
    Uma modsuit com blindagem de plastitânio cara para uso do chefe de segurança.

selectable-set-engineering-voidsuit-name = Traje Espacial de Engenharia
selectable-set-engineering-voidsuit-desc =
    Um traje espacial leve para reparos de baixa intensidade ao redor da estação

selectable-set-engineering-modsuit-name = Modsuite de Engenharia 'Sapador'
selectable-set-engineering-modsuit-desc =
    Uma modsuit modular com proteção contra explosões aumentada e o grande visor
    vulnerável substituído por câmeras externas para proteger melhor contra explosões
    e outras ameaças externas.
