ent-PowerCellMedium = célula de energia de capacidade média
    .suffix = Cheia
    .desc = Uma célula de energia recarregável. Esta é a versão popular e confiável.

ent-PowerCellMicroreactor = célula de microrreator
    .suffix = Cheia
