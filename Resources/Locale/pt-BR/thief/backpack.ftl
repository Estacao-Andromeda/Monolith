thief-backpack-window-title = kit indeterminado

thief-backpack-window-description =
    Dentro estão suas ferramentas de trabalho, que se dissolverão quando você estiver pronto.
    Escolha {$maxCount} diferentes {$maxCount ->
        [1] kit
        *[other] kits
    } da lista.

thief-backpack-window-selected = Kits selecionados: ({$selectedCount}/{$maxCount})

thief-backpack-window-approve-button = Aprovar
thief-backpack-button-select = Selecionar [  ]
thief-backpack-button-deselect = Selecionar [X]

# Kits

thief-backpack-category-chameleon-name = kit camaleão
thief-backpack-category-chameleon-description =
    Você é todos e ninguém; você é um mestre do disfarce.
    Inclui: Um conjunto completo de roupas camaleão,
    um projetor camaleão e um ID de Agente.
    Disfarce-se de qualquer pessoa e coisa.

thief-backpack-category-tools-name = kit de arrombamento
thief-backpack-category-tools-description =
    Qual é aquele som? Um C4 batendo à porta deles.
    Nenhum obstáculo pode impedi-lo!
    Inclui: Dois C4, uma multiferramenta, sinalizador remoto, alicate hidráulico,
    soldador avançado, óculos de engenharia e luvas isolantes.

thief-backpack-category-chemistry-name = kit de anatomia
thief-backpack-category-chemistry-description =
    Você alcançou o desempenho físico máximo... com um pouco de ajuda.
    Inclui: Implantador de armazenamento, implantador de embaralhador de DNA,
    frasco de efedrina, seringa, frasco vazio e sabômega

thief-backpack-category-syndie-name = kit sindicato
thief-backpack-category-syndie-description =
    Bugigangas de um passado renegado, ou roubadas de um agente descuidado?
    Você fez algumas conexões. Whisky, eco...
    Inclui: Um Emag, Quebrador de Acesso, cigarros Interdyne, uma palavra-código do Sindicato,
    um Jammer de Rádio, um isqueiro e alguns estranhos cristais vermelhos.

thief-backpack-category-sleeper-name = kit de sono
thief-backpack-category-sleeper-description =
    Até fecharmos os olhos para sempre, use suas prescrições ilegais
    para manter outros adormecidos.
    Inclui: Tanque de óxido nitroso sonífero, dois frascos de noturnina,
    e um hipopen.

thief-backpack-category-communicator-name = kit de comunicador
thief-backpack-category-communicator-description =
    Dinheiro é poder, e segredos são dinheiro. Use sua língua de prata
    e riqueza para subverter a estação.
    Inclui: Chave mestra para todos os canais da estação, uma caneta CyberSun,
    máscara camaleão de voz e 20k créditos dentro de uma maleta.

thief-backpack-category-smuggler-name = kit de contrabando
thief-backpack-category-smuggler-description =
    Todos os ladrões precisam de algum lugar para esconder suas mercadorias na escuridão.
    Não esqueça de vincular seu fulton.
    Inclui: Sinalizador fulton, 10 fultons, 3 granadas de fumaça,
    e uma caixa invisível para esconder saque valioso.
