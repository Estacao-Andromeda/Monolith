signal-port-name-pressed = Pressionado

signal-port-description-pressed = Esta porta é invocada sempre que o transmissor é ativado.

signal-port-name-on-transmitter = Ligar

signal-port-description-on-transmitter = Esta porta é invocada sempre que o transmissor é ligado.

signal-port-name-off-transmitter = Desligar

signal-port-description-off-transmitter = Esta porta é invocada sempre que o transmissor é desligado.

signal-port-name-status-transmitter = Estado

signal-port-description-status-transmitter = Esta porta é invocada com ALTO ou BAIXO dependendo do status do transmissor.

signal-port-name-left = Esquerda

signal-port-description-left = Esta porta é invocada sempre que a alavanca é movida para a posição mais à esquerda.

signal-port-name-right = Direita

signal-port-description-right = Esta porta é invocada sempre que a alavanca é movida para a posição mais à direita.

signal-port-name-doorstatus = Status da porta

signal-port-description-doorstatus = Esta porta é invocada com ALTO quando a porta abre e BAIXO quando a porta termina de fechar.

signal-port-name-dockstatus = Status de acoplamento

signal-port-description-dockstatus = Esta porta é invocada com ALTO quando acoplado e BAIXO quando desacoplado.

signal-port-name-middle = Meio

signal-port-description-middle = Esta porta é invocada sempre que a alavanca é movida para a posição neutra.

signal-port-name-timer-trigger = Gatilho do temporizador

signal-port-description-timer-trigger = Esta porta é invocada sempre que o temporizador dispara.

signal-port-name-timer-start = Início do temporizador

signal-port-description-timer-start = Esta porta é invocada sempre que o temporizador inicia.

signal-port-name-logic-output = Saída

signal-port-description-logic-output = Esta porta é invocada com ALTO ou BAIXO dependendo do portão selecionado e das entradas.

signal-port-name-logic-output-high = Saída alta

signal-port-description-logic-output-high = Esta porta é invocada sempre que a entrada tem uma borda de subida.

signal-port-name-logic-output-low = Saída baixa

signal-port-description-logic-output-low = Esta porta é invocada sempre que a entrada tem uma borda de descida.

signal-port-name-air-danger = Perigo

signal-port-description-air-danger = Esta porta é invocada com ALTO quando em modo de perigo e BAIXO quando não.

signal-port-name-air-warning = Aviso

signal-port-description-air-warning = Esta porta é invocada com ALTO quando em modo de aviso e BAIXO quando não.

signal-port-name-air-normal = Normal

signal-port-description-air-normal = Esta porta é invocada com ALTO quando em modo normal e BAIXO quando não.

signal-port-name-decaying = Decaindo

signal-port-description-decaying = Esta porta é invocada quando uma anomalia vinculada começa a decair.

signal-port-name-stabilize = Estabilizar

signal-port-description-stabilize = Esta porta é invocada quando uma anomalia vinculada é normalizada.

signal-port-name-growing = Crescendo

signal-port-description-growing = Esta porta é invocada quando uma anomalia vinculada começa a crescer.

signal-port-name-pulse = Pulso

signal-port-description-pulse = Esta porta é invocada quando uma anomalia vinculada está pulsando.

signal-port-name-supercrit = Supercrítico

signal-port-description-supercrit = Esta porta é invocada quando uma anomalia vinculada explode após o estado supercrítico.

signal-port-name-power-charging = Carregando

signal-port-description-power-charging = Esta porta é invocada com ALTO quando a bateria está ganhando carga e BAIXO quando não.

signal-port-name-power-discharging = Descarregando

signal-port-description-power-discharging = Esta porta é invocada com ALTO quando a bateria está perdendo carga e BAIXO quando não.
